# Card libraries — your set folders and Card_Backs live in sets_folder/ and are
# NEVER committed. Only the explanatory README is tracked. (toPrint = old name.)
/sets_folder/*
!/sets_folder/README.md
/toPrint/*
!/toPrint/README.md

# Generated order.xml output (manifests + order.xml)
/MPC_XML/
/builds/
mpc_manifest.json
*.mpc_manifest.json

# Cloned mpc-autofill desktop tool + its venv
/.lotr-autofill/

# Downloaded RingsDB card images (should live in the OS temp dir; ignored here
# as a safety net in case a cache is ever pointed inside the repo)
ringsdb-cache/
lotr-autofill-ringsdb/

# PyInstaller build artifacts
/build/
/dist/
*.spec

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
