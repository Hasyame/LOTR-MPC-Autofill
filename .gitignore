# Card libraries live in sets_folder/. Set folders (and the cards inside them)
# are NEVER committed. The shared card BACKS (Card_Backs/) and the README ARE
# tracked — everyone needs the same encounter/player backs. (toPrint = old name.)
/sets_folder/*
!/sets_folder/README.md
!/sets_folder/Card_Backs
/toPrint/*
!/toPrint/README.md
!/toPrint/Card_Backs

# Generated order.xml output (manifests + order.xml)
/MPC_XML/
/builds/
mpc_manifest.json
*.mpc_manifest.json

# Cloned mpc-autofill desktop tool + its venv
/.lotr-autofill/

# Downloaded RingsDB card images (should live in the OS temp dir; ignored here
# as a safety net in case a cache is ever pointed inside the repo)
ringsdb-cache/
lotr-autofill-ringsdb/

# PyInstaller build artifacts
/build/
/dist/
*.spec
# The built executable now lands in the project root (release asset, not committed).
/lotr-autofill.exe
/lotr-autofill

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
